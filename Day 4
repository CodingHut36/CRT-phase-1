// Nested Loop 
// Program 4 - star pattern triangle 

#include <iostream>
using namespace std;

int main() {
  int n;
  cin >> n;
  for (int i = 1; i <= n; i++) {
    
    for (int j = 1; j <= n - i; j++) {
      cout << " ";
    }
    
    for (int j = 1; j <= i; j++) {
      cout << "*";
    }
    cout << endl;
  }
  return 0;
}
