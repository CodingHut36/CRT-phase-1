// Nested Loop 
// Program 2 - star pattern square 

#include <iostream>
using namespace std;

int  main () {
    for(int i = 1; i<=10 ; i++) {
        for (int j =1; j<=10 ; j++){
            cout << "* ";
        }
        cout <<"\n";
    }
    
    return 0 ;
    
    
}
